// OpenClaw — configuration with Telegram channel
// File location: /data/.openclaw/openclaw.json  (Docker/VPS setup)
//                ~/.openclaw/config.json5        (native/local install)
//
// OpenClaw detects changes to this file automatically — no restart required.
// All secrets must be environment variable references. Never hardcode tokens.
{
  // Model provider
  agents: {
    defaults: {
      model: {
        // Replace with your chosen provider/model
        primary: "anthropic/claude-sonnet-4-5",
      },
      // Workspace directory where SOUL.md lives
      workspace: "/data/.openclaw/workspace",
    },
  },

  // Telegram channel
  channels: {
    telegram: {
      enabled: true,

      // IMPORTANT: always use env var reference — never paste the raw token here.
      // A hardcoded token can leak through backups, screenshots, or prompt injection.
      botToken: "${TELEGRAM_BOT_TOKEN}",

      // Access control:
      //   "open"      — anyone can message the bot (never use in production)
      //   "allowlist" — only listed numeric user IDs can message (recommended)
      //   "closed"    — bot accepts no messages (maintenance mode)
      dmPolicy: "allowlist",

      // Numeric Telegram user IDs allowed to message the bot.
      // Get your ID: send a message to your bot, then open:
      //   https://api.telegram.org/bot{TOKEN}/getUpdates
      // Find "from": {"id": 123456789} — that number is your ID.
      //
      // WARNING: without this, anyone who finds your bot username
      // can send it commands that execute on your server.
      allowFrom: [
        123456789,   // Replace with your actual numeric user ID
      ],

      // Disable the bot in all group chats — respond only in direct messages
      groups: {
        "*": {
          enabled: false,
        },
      },

      // Route to a specific agent (optional, default: "main")
      // agentId: "main",
    },
  },

  // Gateway — keep on loopback, use SSH tunnel or Tailscale for remote access
  gateway: {
    listen: "127.0.0.1:18789",
    auth: {
      token: "${OPENCLAW_GATEWAY_TOKEN}",
    },
  },

  // Hooks disabled — enable when connecting n8n
  hooks: {
    enabled: false,
  },
}
