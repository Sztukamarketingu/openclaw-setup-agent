# =============================================================================
# OpenClaw Setup Agent — environment variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
#
# Fields marked REQUIRED must be filled before running the agent.
# Fields marked OPTIONAL can be left empty and added later.
# =============================================================================


# -----------------------------------------------------------------------------
# HOSTINGER API — REQUIRED
# Get your API key: Hostinger panel → Account → API tokens
# Docs: https://developers.hostinger.com
# -----------------------------------------------------------------------------

HOSTINGER_API_KEY=


# -----------------------------------------------------------------------------
# VPS ACCESS — REQUIRED
# Your Hostinger VPS connection details
# -----------------------------------------------------------------------------

# VPS IP address (find in Hostinger panel → VPS → your server)
VPS_HOSTNAME=

# SSH username (usually root for Hostinger VPS)
VPS_USERNAME=root

# SSH port (default is 22)
VPS_PORT=22

# Path to your SSH private key on this machine
# Example: /Users/yourname/.ssh/id_rsa or ~/.ssh/hostinger_vps
VPS_SSH_KEY_PATH=~/.ssh/id_rsa


# -----------------------------------------------------------------------------
# MODEL PROVIDER — fill in at least ONE
# The agent will ask which provider you want to use during setup
# -----------------------------------------------------------------------------

# Anthropic Claude (recommended)
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=

# OpenAI
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Nexos AI Gateway (for cost control and multi-model routing)
# Get credentials from your Nexos account
NEXOS_API_KEY=
NEXOS_BASE_URL=

# OpenRouter (access to many models through one key)
# Get key: https://openrouter.ai/keys
OPENROUTER_API_KEY=


# -----------------------------------------------------------------------------
# TELEGRAM — REQUIRED for first channel setup
# Create a bot: open Telegram → @BotFather → /newbot
# -----------------------------------------------------------------------------

TELEGRAM_BOT_TOKEN=


# -----------------------------------------------------------------------------
# OPENCLAW SECURITY TOKENS — REQUIRED
# Generate random strings (32+ characters recommended)
# Use: openssl rand -hex 32
# IMPORTANT: dashboard token and hooks token must be different values
# -----------------------------------------------------------------------------

# Token for OpenClaw Control UI dashboard access
OPENCLAW_GATEWAY_TOKEN=

# Token for webhook endpoints (/hooks/agent, /hooks/wake)
# This is what n8n sends in Authorization: Bearer header
OPENCLAW_HOOKS_TOKEN=


# -----------------------------------------------------------------------------
# N8N — OPTIONAL
# Fill in if you want to connect n8n workflows to OpenClaw
# -----------------------------------------------------------------------------

# n8n instance URL (e.g. http://localhost:5678 or https://your-n8n.domain.com)
N8N_BASE_URL=

# n8n API key (n8n Settings → API → Create API Key)
N8N_API_KEY=


# -----------------------------------------------------------------------------
# QDRANT — OPTIONAL
# Fill in if you want semantic memory / RAG capabilities (advanced, later phase)
# -----------------------------------------------------------------------------

QDRANT_URL=
QDRANT_API_KEY=
