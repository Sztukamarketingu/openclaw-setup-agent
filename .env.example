# =============================================================================
# OpenClaw Setup Agent — dane połączenia z VPS
# =============================================================================
# Skopiuj ten plik: cp .env.example .env
# Uzupełnij poniższe 5 pól — to wszystko czego agent potrzebuje lokalnie.
#
# Klucze API (Anthropic, Telegram, tokeny OpenClaw itp.) NIE trafiają tutaj.
# Agent przeprowadzi Cię przez dodanie ich bezpośrednio w Hostinger
# w sekcji Environment Variables — tam gdzie działają bezpiecznie na VPS.
# =============================================================================


# Klucz API Hostinger — potrzebny do zarządzania VPS przez API
# Gdzie go znaleźć: panel Hostinger → konto → API tokens
HOSTINGER_API_KEY=

# Adres IP Twojego VPS
# Gdzie go znaleźć: panel Hostinger → VPS → szczegóły serwera
VPS_HOSTNAME=

# Nazwa użytkownika SSH (domyślnie root na VPS Hostinger)
VPS_USERNAME=root

# Port SSH (domyślnie 22)
VPS_PORT=22

# Ścieżka do klucza prywatnego SSH na Twoim komputerze
# Przykład: ~/.ssh/id_rsa  lub  ~/.ssh/hostinger_vps
VPS_SSH_KEY_PATH=~/.ssh/id_rsa


# =============================================================================
# N8N — opcjonalne, tylko jeśli chcesz żeby agent budował workflow w n8n
# =============================================================================
# Bez tych danych agent skonfiguruje tylko stronę OpenClaw (hooki, tokeny).
# Z tymi danymi agent może też tworzyć gotowe workflow bezpośrednio w n8n.
#
# N8N_BASE_URL — adres Twojej instancji n8n, np. http://localhost:5678
#                lub https://twoja-domena.com/n8n
# N8N_API_KEY  — n8n → Settings → API → Create API Key
# =============================================================================

N8N_BASE_URL=
N8N_API_KEY=
